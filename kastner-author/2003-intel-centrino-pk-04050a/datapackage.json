{
  "name": "2003-intel-centrino-pk-04050a",
  "title": "Intel's Centrino: Don't Man the Barricades",
  "description": "Frictionless Data Package containing structured observations from a 2003 Aberdeen Group opinion piece by Peter S. Kastner about Intel's Centrino wireless notebook platform launch and enterprise wireless adoption.",
  "version": "1.0.0",
  "created": "2026-03-16",
  "licenses": [
    {
      "name": "CC-BY-4.0",
